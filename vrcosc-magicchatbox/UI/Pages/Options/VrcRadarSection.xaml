<UserControl
    x:Class="vrcosc_magicchatbox.UI.Pages.Options.VrcRadarSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:modules="clr-namespace:vrcosc_magicchatbox.Classes.Modules"
    xmlns:sections="clr-namespace:vrcosc_magicchatbox.ViewModels.Sections"
    d:DataContext="{d:DesignInstance Type=sections:VrcRadarSectionViewModel,
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Resources/SharedConverters.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0,5,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.Background>
            <LinearGradientBrush SpreadMethod="Pad" StartPoint="1,1" EndPoint="0,0">
                <GradientStop Color="{StaticResource SurfaceGradientStartColor}" />
                <GradientStop Offset="1" Color="{StaticResource SurfaceGradientEndColor}" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Section Header -->
        <Grid Grid.Row="0">
            <ToggleButton
                Width="Auto"
                Height="30"
                HorizontalAlignment="Left"
                FontSize="15"
                FontWeight="Bold"
                Foreground="{StaticResource TextSectionHeaderBrush}"
                IsChecked="{Binding AppSettings.Settings_VrcRadar, Mode=TwoWay}"
                Style="{StaticResource ExpandCollapseToggleButtonStyle}"
                Tag="VRChat Radar options"
                TextOptions.TextRenderingMode="ClearType" />
        </Grid>

        <!-- Collapsible Content -->
        <Grid
            Grid.Row="1"
            Height="Auto"
            Margin="34,10,0,0"
            Visibility="{Binding AppSettings.Settings_VrcRadar, Converter={StaticResource InverseBoolToHiddenConverter}, UpdateSourceTrigger=PropertyChanged}">
            <StackPanel>

                <!-- Live status bar -->
                <Border
                    Margin="0,0,0,8"
                    Padding="8,5"
                    Background="{StaticResource SurfaceCardBrush}"
                    CornerRadius="5,0,0,5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock
                                FontSize="13"
                                Foreground="{StaticResource TextBodyBrush}"
                                Text="🌎 " />
                            <TextBlock
                                FontSize="13"
                                Foreground="{StaticResource TextBodyBrush}"
                                Text="{Binding Modules.VrcRadar.CurrentWorldName, FallbackValue='Not in a world'}" />
                            <TextBlock
                                Margin="12,0,0,0"
                                FontSize="13"
                                Foreground="{StaticResource TextLabelBrush}"
                                Text="👥 " />
                            <TextBlock
                                FontSize="13"
                                Foreground="{StaticResource TextLabelBrush}"
                                Text="{Binding Modules.VrcRadar.PlayerCount, FallbackValue='0'}" />
                            <TextBlock
                                Margin="12,0,0,0"
                                FontSize="12"
                                Foreground="{StaticResource TextLabelBrush}"
                                Text="{Binding Modules.VrcRadar.InstanceType, FallbackValue=''}" />
                            <TextBlock
                                Margin="6,0,0,0"
                                FontSize="12"
                                Foreground="{StaticResource TextLabelBrush}"
                                Text="{Binding Modules.VrcRadar.Region, FallbackValue=''}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button
                                Width="auto"
                                Height="26"
                                Padding="8,3"
                                Command="{Binding StartRadarCommand}"
                                Content="▶ Start"
                                FontSize="12"
                                Style="{StaticResource Status_Button_style}"
                                Visibility="{Binding Modules.VrcRadar.IsRadarRunning, Converter={StaticResource InverseBoolToVisibilityConverter}, FallbackValue=Visible}" />
                            <Button
                                Width="auto"
                                Height="26"
                                Padding="8,3"
                                Command="{Binding StopRadarCommand}"
                                Content="⏹ Stop"
                                FontSize="12"
                                Style="{StaticResource Status_Button_style}"
                                Visibility="{Binding Modules.VrcRadar.IsRadarRunning, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- DISPLAY MODE -->
                <TextBlock
                    Margin="0,0,0,3"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextSectionHeaderBrush}"
                    Text="Display Mode" />
                <ComboBox
                    Width="200"
                    Margin="0,0,0,8"
                    HorizontalAlignment="Left"
                    FontSize="12"
                    ItemsSource="{Binding DisplayModes}"
                    SelectedItem="{Binding RadarSettings.DisplayMode, Mode=TwoWay}" />
                <TextBlock
                    Margin="0,0,0,10"
                    FontSize="11"
                    Foreground="{StaticResource TextLabelBrush}"
                    Opacity="0.5"
                    TextWrapping="Wrap"
                    Text="AlwaysShow: permanently shows world info. TransientOnly: only shows during events. EventOverlay: shows world info, overlays events." />

                <!-- WORLD INFO TOGGLES -->
                <TextBlock
                    Margin="0,5,0,3"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextSectionHeaderBrush}"
                    Text="World Info" />
                <CheckBox
                    IsChecked="{Binding RadarSettings.ShowInstanceType, Mode=TwoWay}"
                    Style="{DynamicResource SettingsCheckbox}">Show instance type (Private/Group/Public)</CheckBox>
                <CheckBox
                    IsChecked="{Binding RadarSettings.ShowRegion, Mode=TwoWay}"
                    Style="{DynamicResource SettingsCheckbox}">Show server region</CheckBox>

                <!-- EVENTS -->
                <TextBlock
                    Margin="0,10,0,3"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextSectionHeaderBrush}"
                    Text="Events" />
                <CheckBox
                    IsChecked="{Binding RadarSettings.AnnounceJoins, Mode=TwoWay}"
                    Style="{DynamicResource SettingsCheckbox}">Announce player joins</CheckBox>
                <CheckBox
                    IsChecked="{Binding RadarSettings.AnnounceLeaves, Mode=TwoWay}"
                    Style="{DynamicResource SettingsCheckbox}">Announce player leaves</CheckBox>
                <CheckBox
                    IsChecked="{Binding RadarSettings.AnnounceScreenshots, Mode=TwoWay}"
                    Style="{DynamicResource SettingsCheckbox}">Announce screenshots</CheckBox>
                <CheckBox
                    IsChecked="{Binding RadarSettings.WarnOnCrashers, Mode=TwoWay}"
                    Style="{DynamicResource SettingsCheckbox}">Warn on crasher avatars</CheckBox>
                <CheckBox
                    IsChecked="{Binding RadarSettings.ShowWorldDownload, Mode=TwoWay}"
                    Style="{DynamicResource SettingsCheckbox}">Show world loading progress</CheckBox>
                <CheckBox
                    IsChecked="{Binding RadarSettings.ShowLeavingRoom, Mode=TwoWay}"
                    Style="{DynamicResource SettingsCheckbox}">Show "Leaving world..." message</CheckBox>

                <!-- ENCOUNTER DETECTION -->
                <TextBlock
                    Margin="0,10,0,3"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextSectionHeaderBrush}"
                    Text="Encounter Tracking" />
                <CheckBox
                    IsChecked="{Binding RadarSettings.DetectSeenAgain, Mode=TwoWay}"
                    Style="{DynamicResource SettingsCheckbox}">Detect players seen in consecutive rooms</CheckBox>
                <TextBlock
                    Margin="20,2,0,3"
                    FontSize="11"
                    Foreground="{StaticResource TextLabelBrush}"
                    TextWrapping="Wrap"
                    Text="Shows a notification when someone from your last room appears in your new room. Privacy-friendly: off by default, no data leaves your PC." />
                <StackPanel
                    Margin="20,3,0,5"
                    Orientation="Horizontal"
                    Visibility="{Binding RadarSettings.DetectSeenAgain, Converter={StaticResource InverseBoolToHiddenConverter}}">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{StaticResource TextBodyBrush}"
                        Text="Time window (minutes): " />
                    <TextBox
                        Width="50"
                        Padding="3,0"
                        FontSize="12"
                        Text="{Binding RadarSettings.SeenAgainWindowMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- SESSION STATS -->
                <TextBlock
                    Margin="0,10,0,3"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextSectionHeaderBrush}"
                    Text="Session Stats" />
                <StackPanel Margin="0,0,0,3" Orientation="Horizontal">
                    <TextBlock FontSize="12" Foreground="{StaticResource TextLabelBrush}" Text="Worlds visited: " />
                    <TextBlock FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="{Binding Modules.VrcRadar.WorldsVisited, FallbackValue='0'}" />
                    <TextBlock Margin="12,0,0,0" FontSize="12" Foreground="{StaticResource TextLabelBrush}" Text="Unique players: " />
                    <TextBlock FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="{Binding Modules.VrcRadar.UniquePlayersCount, FallbackValue='0'}" />
                    <TextBlock Margin="12,0,0,0" FontSize="12" Foreground="{StaticResource TextLabelBrush}" Text="Joins: " />
                    <TextBlock FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="{Binding Modules.VrcRadar.TotalJoinEvents, FallbackValue='0'}" />
                    <TextBlock Margin="6,0,0,0" FontSize="12" Foreground="{StaticResource TextLabelBrush}" Text="Leaves: " />
                    <TextBlock FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="{Binding Modules.VrcRadar.TotalLeaveEvents, FallbackValue='0'}" />
                </StackPanel>
                <CheckBox
                    IsChecked="{Binding RadarSettings.ShowSessionStatsInChatbox, Mode=TwoWay}"
                    Style="{DynamicResource SettingsCheckbox}">Show session stats in chatbox (after world change)</CheckBox>

                <!-- TEMPLATES -->
                <TextBlock
                    Margin="0,10,0,3"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextSectionHeaderBrush}"
                    Text="Templates" />
                <TextBlock
                    Margin="0,0,0,2"
                    FontSize="11"
                    Foreground="{StaticResource TextLabelBrush}"
                    Opacity="0.6"
                    TextWrapping="Wrap"
                    Text="Placeholders: {master} {world} {count} {peak} {session_time} {app_session} {offline} {type} {region} {owner} {user} {size} {speed} {worlds} {players}  ·  Use \n for new line" />
                <Grid Margin="0,3,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="World info:" VerticalAlignment="Center" Margin="0,2" />
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="0,2">
                        <TextBox Padding="3,0" FontSize="12" MinWidth="200" Text="{Binding RadarSettings.TemplateWorld, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <ComboBox
                            Width="100"
                            Margin="6,0,0,0"
                            FontSize="11"
                            ItemsSource="{Binding WorldPresetNames}"
                            SelectedItem="{Binding SelectedWorldPresetName, Mode=TwoWay}"
                            ToolTip="Quick-fill a preset template" />
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0" FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="Player joined:" VerticalAlignment="Center" Margin="0,2" />
                    <TextBox Grid.Row="1" Grid.Column="1" Padding="3,0" FontSize="12" Margin="0,2" Text="{Binding RadarSettings.TemplateJoin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="2" Grid.Column="0" FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="Player left:" VerticalAlignment="Center" Margin="0,2" />
                    <TextBox Grid.Row="2" Grid.Column="1" Padding="3,0" FontSize="12" Margin="0,2" Text="{Binding RadarSettings.TemplateLeave, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="3" Grid.Column="0" FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="Screenshot:" VerticalAlignment="Center" Margin="0,2" />
                    <TextBox Grid.Row="3" Grid.Column="1" Padding="3,0" FontSize="12" Margin="0,2" Text="{Binding RadarSettings.TemplateScreenshot, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="4" Grid.Column="0" FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="Crasher:" VerticalAlignment="Center" Margin="0,2" />
                    <TextBox Grid.Row="4" Grid.Column="1" Padding="3,0" FontSize="12" Margin="0,2" Text="{Binding RadarSettings.TemplateCrasher, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="5" Grid.Column="0" FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="Loading world:" VerticalAlignment="Center" Margin="0,2" />
                    <TextBox Grid.Row="5" Grid.Column="1" Padding="3,0" FontSize="12" Margin="0,2" Text="{Binding RadarSettings.TemplateDownload, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="6" Grid.Column="0" FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="Leaving room:" VerticalAlignment="Center" Margin="0,2" />
                    <TextBox Grid.Row="6" Grid.Column="1" Padding="3,0" FontSize="12" Margin="0,2" Text="{Binding RadarSettings.TemplateLeaving, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="7" Grid.Column="0" FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="Seen again:" VerticalAlignment="Center" Margin="0,2" />
                    <TextBox Grid.Row="7" Grid.Column="1" Padding="3,0" FontSize="12" Margin="0,2" Text="{Binding RadarSettings.TemplateSeenAgain, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="8" Grid.Column="0" FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="Session stats:" VerticalAlignment="Center" Margin="0,2" />
                    <TextBox Grid.Row="8" Grid.Column="1" Padding="3,0" FontSize="12" Margin="0,2" Text="{Binding RadarSettings.TemplateSessionStats, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <!-- Live preview -->
                <Border
                    Margin="0,6,0,0"
                    Padding="6,4"
                    Background="{StaticResource SurfaceDarkBrush}"
                    BorderBrush="{StaticResource SurfaceVariantBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
                    <StackPanel>
                        <TextBlock FontSize="10" Foreground="{StaticResource TextLabelBrush}" Opacity="0.5" Text="LIVE PREVIEW" />
                        <TextBlock
                            Margin="0,2,0,0"
                            FontFamily="Comfortaa Light"
                            FontSize="13"
                            Foreground="{StaticResource TextBodyBrush}"
                            TextWrapping="Wrap"
                            Text="{Binding Modules.VrcRadar.CurrentOutputPreview, FallbackValue='(start radar to see preview)'}" />
                    </StackPanel>
                </Border>

                <!-- MASTER ICON -->
                <StackPanel Margin="0,8,0,0" Orientation="Horizontal">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{StaticResource TextBodyBrush}"
                        Text="Master icon: " />
                    <TextBox
                        Width="60"
                        Padding="3,0"
                        FontSize="12"
                        Text="{Binding RadarSettings.MasterIcon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- OSC TRIGGERS -->
                <TextBlock
                    Margin="0,12,0,3"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextSectionHeaderBrush}"
                    Text="OSC Triggers" />
                <CheckBox
                    IsChecked="{Binding RadarSettings.SendCameraFlashOsc, Mode=TwoWay}"
                    Style="{DynamicResource SettingsCheckbox}">Camera flash on screenshot</CheckBox>
                <StackPanel
                    Margin="20,2,0,5"
                    Orientation="Horizontal"
                    Visibility="{Binding RadarSettings.SendCameraFlashOsc, Converter={StaticResource InverseBoolToHiddenConverter}}">
                    <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="OSC path: " />
                    <TextBox Width="250" Padding="3,0" FontSize="12" Text="{Binding RadarSettings.OscCameraFlashParam, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
                <CheckBox
                    IsChecked="{Binding RadarSettings.SendPanicShieldOsc, Mode=TwoWay}"
                    Style="{DynamicResource SettingsCheckbox}">Panic shield on crasher detection</CheckBox>
                <StackPanel
                    Margin="20,2,0,5"
                    Orientation="Horizontal"
                    Visibility="{Binding RadarSettings.SendPanicShieldOsc, Converter={StaticResource InverseBoolToHiddenConverter}}">
                    <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="OSC path: " />
                    <TextBox Width="250" Padding="3,0" FontSize="12" Text="{Binding RadarSettings.OscPanicShieldParam, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <!-- Spacing -->
                <Border Height="10" />

                <!-- Performance / Limits -->
                <TextBlock
                    Margin="0,12,0,3"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{StaticResource TextSectionHeaderBrush}"
                    Text="Performance" />
                <StackPanel Margin="0,4,0,4" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="Max backfill scan size (MB): " />
                    <TextBox Width="60" Padding="3,0" FontSize="12" Text="{Binding RadarSettings.MaxBackfillSizeMb, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextSubtleBrush}" Text="(1–200)" />
                </StackPanel>
                <StackPanel Margin="0,2,0,4" Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{StaticResource TextBodyBrush}" Text="Max log entries in memory: " />
                    <TextBox Width="80" Padding="3,0" FontSize="12" Text="{Binding RadarSettings.MaxLogEntries, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="{StaticResource TextSubtleBrush}" Text="(500–100,000)" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
