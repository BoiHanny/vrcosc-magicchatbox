<UserControl
    x:Class="vrcosc_magicchatbox.UI.Pages.Options.AppOptionsSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:vrcosc_magicchatbox.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:ViewModel,
                                     IsDesignTimeCreatable=True}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Resources/SharedConverters.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0,5,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.Background>
                            <LinearGradientBrush SpreadMethod="Pad" StartPoint="1,1" EndPoint="0,0">
                                <GradientStop Color="{StaticResource SurfaceGradientStartColor}" />
                                <GradientStop Offset="1" Color="{StaticResource SurfaceGradientEndColor}" />
                            </LinearGradientBrush>
                        </Grid.Background>
                        <Grid Grid.Row="0">
                            <ToggleButton
                                Width="Auto"
                                Height="30"
                                HorizontalAlignment="Left"
                                FontSize="15"
                                FontWeight="Bold"
                                Foreground="{StaticResource TextSectionHeaderBrush}"
                                IsChecked="{Binding AppSettings.Settings_AppOptions, Mode=TwoWay}"
                                Style="{StaticResource ExpandCollapseToggleButtonStyle}"
                                Tag="App options"
                                TextOptions.TextRenderingMode="ClearType" />
                        </Grid>
                        <Grid
                            Grid.Row="1"
                            Height="Auto"
                            Margin="34,10,0,0"
                            Visibility="{Binding AppSettings.Settings_AppOptions, Converter={StaticResource InverseBoolToHiddenConverter}, UpdateSourceTrigger=PropertyChanged}">
                            <StackPanel>
                                <StackPanel>
                                    <TextBlock
                                        Grid.Column="0"
                                        Padding="0,0,0,3"
                                        HorizontalAlignment="Left"
                                         FontFamily="Albert Sans Thin"
                                         FontSize="15"
                                         Foreground="{StaticResource TextLabelBrush}"
                                         Style="{StaticResource OptionSubsectionHeaderStyle}"
                                         Text="Local IP address" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBox
                                            x:Name="OSCIPBox"
                                            Width="100"
                                            Padding="5,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalContentAlignment="Center"
                                            FontSize="15"
                                            Text="{Binding OscSettings.OscIP, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button
                                            x:Name="ResetIP_btn"
                                            Width="auto"
                                            Margin="5,0,0,0"
                                            Padding="5"
                                            Command="{Binding ResetOscIpCommand}"
                                            Style="{StaticResource Status_Button_style}">
                                            <Button.ContentTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">

                                                        <Image
                                                            Width="15"
                                                            Height="15"
                                                            Margin="0,0,3,0"
                                                            RenderOptions.BitmapScalingMode="HighQuality"
                                                            Source="/Img/Icons/Load_ico.png" />
                                                        <TextBlock
                                                            Margin="0,-1,5,0"
                                                            VerticalAlignment="Center"
                                                            FontSize="14"
                                                            FontWeight="DemiBold"
                                                            Foreground="{StaticResource TextSubtlePurpleBrush}"
                                                            Text="Default" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </Button.ContentTemplate>
                                        </Button>
                                    </StackPanel>

                                    <TextBlock
                                        Grid.Column="0"
                                        Padding="0,10,0,3"
                                        HorizontalAlignment="Left"
                                         FontFamily="Albert Sans Thin"
                                         FontSize="15"
                                         Foreground="{StaticResource TextLabelBrush}"
                                         Style="{StaticResource OptionSubsectionHeaderStyle}"
                                         Text="Port (outgoing)" />
                                    <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                        <TextBox
                                            x:Name="OSCPortOut"
                                            Width="100"
                                            Padding="5,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalContentAlignment="Center"
                                            FontSize="15"
                                            Text="{Binding OscSettings.OscPortOut, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <Button
                                            x:Name="ResetOSCPortOut_btn"
                                            Width="auto"
                                            Margin="5,0,0,0"
                                            Padding="5"
                                            Command="{Binding ResetOscPortCommand}"
                                            Style="{StaticResource Status_Button_style}">
                                            <Button.ContentTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">

                                                        <Image
                                                            Width="15"
                                                            Height="15"
                                                            Margin="0,0,3,0"
                                                            RenderOptions.BitmapScalingMode="HighQuality"
                                                            Source="/Img/Icons/Load_ico.png" />
                                                        <TextBlock
                                                            Margin="0,-1,5,0"
                                                            VerticalAlignment="Center"
                                                            FontSize="14"
                                                            FontWeight="DemiBold"
                                                            Foreground="{StaticResource TextSubtlePurpleBrush}"
                                                            Text="Default" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </Button.ContentTemplate>
                                        </Button>
                                    </StackPanel>
                                    <CheckBox
                                        x:Name="UnmuteMainOutput_checkbox"
                                        IsChecked="{Binding OscSettings.UnmuteMainOutput, Mode=TwoWay}"
                                        Style="{DynamicResource SettingsCheckbox}">
                                        Toggle voice on main output
                                    </CheckBox>
                                </StackPanel>
                                <TextBlock
                                    Width="auto"
                                    Padding="0,0"
                                    VerticalAlignment="Center"
                                     FontFamily="Albert Sans Thin"
                                     FontSize="15"
                                     Foreground="{StaticResource TextLabelBrush}"
                                     Style="{StaticResource OptionSubsectionHeaderStyle}"
                                     Text="OSC update rate" />
                                <StackPanel Margin="0,0,0,7" Orientation="Horizontal">
                                    <Slider
                                        x:Name="ScanningIntervalSensitivitySlider"
                                        Width="134.5"
                                        Height="12"
                                        Margin="2.2,0,4.5,0"
                                        IsSnapToTickEnabled="True"
                                        Maximum="10"
                                        Minimum="1.6"
                                        Style="{StaticResource CustomSlider}"
                                        TickFrequency="0.1"
                                        Value="{Binding AppSettings.ScanningInterval, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBlock
                                        Width="auto"
                                        Padding="5,0"
                                        VerticalAlignment="Center"
                                        FontFamily="Albert Sans Thin"
                                        FontSize="13"
                                        Foreground="{StaticResource BorderMutedBrush}"
                                        Text="{Binding AppSettings.ScanningInterval}" />
                                    <TextBlock
                                        Width="auto"
                                        Margin="-2,5"
                                        VerticalAlignment="Center"
                                        FontFamily="Albert Sans Thin"
                                        FontSize="13"
                                        Foreground="{StaticResource BorderMutedBrush}"
                                        Text="sec" />
                                </StackPanel>

                                <CheckBox
                                    x:Name="SecOSC_checkbox"
                                    IsChecked="{Binding OscSettings.SecOSC, Mode=TwoWay}"
                                    Style="{DynamicResource SettingsCheckbox}">
                                    2nd VRChat output
                                </CheckBox>
                                <Border
                                    Margin="0,0,0,15"
                                    Style="{StaticResource OptionCardStyle}"
                                    Visibility="{Binding OscSettings.SecOSC, Converter={StaticResource InverseBoolToHiddenConverter}, UpdateSourceTrigger=PropertyChanged}">
                                    <StackPanel Margin="5">
                                        <TextBlock
                                            Grid.Column="0"
                                            Padding="0,0,0,0"
                                            HorizontalAlignment="Left"
                                             FontFamily="Albert Sans Thin"
                                             FontSize="15"
                                             Foreground="{StaticResource TextLabelBrush}"
                                             Style="{StaticResource OptionSubsectionHeaderStyle}"
                                             Text="2nd IP address" />
                                        <TextBox
                                            x:Name="SecOSCIP"
                                            Width="100"
                                            Margin="0,3,0,5"
                                            Padding="5,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalContentAlignment="Center"
                                            FontSize="15"
                                            Text="{Binding OscSettings.SecOSCIP, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock
                                            Grid.Column="0"
                                            Padding="0,0,0,0"
                                            HorizontalAlignment="Left"
                                             FontFamily="Albert Sans Thin"
                                             FontSize="15"
                                             Foreground="{StaticResource TextLabelBrush}"
                                             Style="{StaticResource OptionSubsectionHeaderStyle}"
                                             Text="2nd VRChat port (outgoing)" />
                                        <TextBox
                                            x:Name="SecOSCPort"
                                            Width="100"
                                            Margin="0,3,0,0"
                                            Padding="5,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalContentAlignment="Center"
                                            FontSize="15"
                                            Text="{Binding OscSettings.SecOSCPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox
                                            x:Name="ToggleVoiceSec"
                                            Margin="0,6,0,0"
                                            IsChecked="{Binding OscSettings.UnmuteSecOutput, Mode=TwoWay}"
                                            Style="{DynamicResource SettingsCheckbox}">
                                            Toggle voice on this output
                                        </CheckBox>
                                    </StackPanel>
                                </Border>

                                <CheckBox
                                    x:Name="ThirdOSC_checkbox"
                                    IsChecked="{Binding OscSettings.ThirdOSC, Mode=TwoWay}"
                                    Style="{DynamicResource SettingsCheckbox}">
                                    3rd VRChat output
                                </CheckBox>
                                <Border
                                    Margin="0,0,0,15"
                                    Style="{StaticResource OptionCardStyle}"
                                    Visibility="{Binding OscSettings.ThirdOSC, Converter={StaticResource InverseBoolToHiddenConverter}, UpdateSourceTrigger=PropertyChanged}">
                                    <StackPanel Margin="5">
                                        <TextBlock
                                            Grid.Column="0"
                                            Padding="0,0,0,0"
                                            HorizontalAlignment="Left"
                                             FontFamily="Albert Sans Thin"
                                             FontSize="15"
                                             Foreground="{StaticResource TextLabelBrush}"
                                             Style="{StaticResource OptionSubsectionHeaderStyle}"
                                             Text="3rd IP address" />
                                        <TextBox
                                            x:Name="ThirdOSCIP"
                                            Width="100"
                                            Margin="0,3,0,5"
                                            Padding="5,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalContentAlignment="Center"
                                            FontSize="15"
                                            Text="{Binding OscSettings.ThirdOSCIP, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock
                                            Grid.Column="0"
                                            Padding="0,0,0,0"
                                            HorizontalAlignment="Left"
                                             FontFamily="Albert Sans Thin"
                                             FontSize="15"
                                             Foreground="{StaticResource TextLabelBrush}"
                                             Style="{StaticResource OptionSubsectionHeaderStyle}"
                                             Text="3rd VRChat port (outgoing)" />
                                        <TextBox
                                            x:Name="ThirdOSCPort"
                                            Width="100"
                                            Margin="0,3,0,0"
                                            Padding="5,0,0,0"
                                            HorizontalAlignment="Left"
                                            VerticalContentAlignment="Center"
                                            FontSize="15"
                                            Text="{Binding OscSettings.ThirdOSCPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox
                                            x:Name="ToggleVoiceThird"
                                            Margin="0,6,0,0"
                                            IsChecked="{Binding OscSettings.UnmuteThirdOutput, Mode=TwoWay}"
                                            Style="{DynamicResource SettingsCheckbox}">
                                            Toggle voice on this output
                                        </CheckBox>
                                    </StackPanel>
                                </Border>
                                <CheckBox
                                    x:Name="CountOculusSystemAsVR_checkbox"
                                    IsChecked="{Binding AppSettings.CountOculusSystemAsVR, Mode=TwoWay}"
                                    Style="{DynamicResource SettingsCheckbox}">
                                    Count Oculus System as VR running (experimental)
                                </CheckBox>

                                <CheckBox
                                    x:Name="WindowOnTop_checkbox"
                                    IsChecked="{Binding AppSettings.Topmost, Mode=TwoWay}"
                                    Style="{DynamicResource SettingsCheckbox}">
                                    Always on top
                                </CheckBox>
                                <CheckBox
                                    x:Name="SeperateWithENTERS_checkbox"
                                    IsChecked="{Binding AppSettings.SeperateWithENTERS, Mode=TwoWay}"
                                    Style="{DynamicResource SettingsCheckbox}">
                                    Separate integrations using 'ENTER' instead of '┆'
                                </CheckBox>
                                <StackPanel Margin="0,0,0,15">
                                    <TextBlock
                                        Padding="0,0,0,3"
                                        HorizontalAlignment="Left"
                                         FontFamily="Albert Sans Thin"
                                         FontSize="15"
                                         Foreground="{StaticResource TextLabelBrush}"
                                         Style="{StaticResource OptionSubsectionHeaderStyle}"
                                         Text="OSC separator (when not using ENTER)" />
                                    <TextBox
                                        x:Name="OscMessageSeparator"
                                        Width="140"
                                        Padding="5,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalContentAlignment="Center"
                                        FontSize="15"
                                        Text="{Binding AppSettings.OscMessageSeparator, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,15">
                                    <TextBlock
                                        Padding="0,0,0,3"
                                        HorizontalAlignment="Left"
                                         FontFamily="Albert Sans Thin"
                                         FontSize="15"
                                         Foreground="{StaticResource TextLabelBrush}"
                                         Style="{StaticResource OptionSubsectionHeaderStyle}"
                                         Text="OSC message prefix" />
                                    <TextBox
                                        x:Name="OscMessagePrefix"
                                        Width="220"
                                        Padding="5,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalContentAlignment="Center"
                                        FontSize="15"
                                        Text="{Binding AppSettings.OscMessagePrefix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,0,15">
                                    <TextBlock
                                        Padding="0,0,0,3"
                                        HorizontalAlignment="Left"
                                         FontFamily="Albert Sans Thin"
                                         FontSize="15"
                                         Foreground="{StaticResource TextLabelBrush}"
                                         Style="{StaticResource OptionSubsectionHeaderStyle}"
                                         Text="OSC message suffix" />
                                    <TextBox
                                        x:Name="OscMessageSuffix"
                                        Width="220"
                                        Padding="5,0,0,0"
                                        HorizontalAlignment="Left"
                                        VerticalContentAlignment="Center"
                                        FontSize="15"
                                        Text="{Binding AppSettings.OscMessageSuffix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <TextBlock
                                     Margin="0,0,0,15"
                                     FontFamily="Albert Sans Thin"
                                     FontSize="13"
                                     Foreground="{StaticResource TextLabelBrush}"
                                     Style="{StaticResource OptionHelpTextStyle}"
                                     Text="Tip: use /n for a new line." />

                                <CheckBox
                                    x:Name="ToggleVoiceWithV"
                                    Margin="0,6,0,0"
                                    IsChecked="{Binding TtsSettings.ToggleVoiceWithV, Mode=TwoWay}"
                                    Style="{DynamicResource SettingsCheckbox}">
                                    Toggle VRChat voice with 'V'
                                </CheckBox>
                                <CheckBox
                                    x:Name="CheckUpdateOnStartup"
                                    Margin="0,6,0,0"
                                    IsChecked="{Binding AppSettings.CheckUpdateOnStartup, Mode=TwoWay}"
                                    Style="{DynamicResource SettingsCheckbox}">
                                    Auto check for updates on startup (recommended)
                                </CheckBox>
                                <CheckBox
                                    x:Name="ToggleJoinedApha"
                                    Margin="0,6,0,15"
                                    Content="Beta channel updates"
                                    Foreground="{Binding UpdateState.VersionTxtColor}"
                                    IsChecked="{Binding AppSettings.JoinedAlphaChannel, Mode=TwoWay}"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                                    Style="{DynamicResource SettingsCheckbox}">
                                    <CheckBox.Effect>
                                        <DropShadowEffect
                                            BlurRadius="15"
                                            Opacity="0.7"
                                            ShadowDepth="0"
                                            Color="{Binding UpdateState.VersionTxtColor}" />
                                    </CheckBox.Effect>
                                </CheckBox>

                                <Button
                                    x:Name="Rollback"
                                    Width="auto"
                                    Height="30"
                                    Margin="0,0,0,5"
                                    Padding="5"
                                    HorizontalAlignment="Left"
                                    Command="{Binding RollbackCommand}"
                                    Opacity="0.7"
                                    Style="{StaticResource UpdatedGreenButtonStyle}"
                                    Visibility="{Binding UpdateState.RollBackUpdateAvailable, Converter={StaticResource InverseBoolToHiddenConverter}}">
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Image
                                                    Height="18"
                                                    Margin="0,0,4,0"
                                                    RenderOptions.BitmapScalingMode="HighQuality"
                                                    Source="/Img/Icons/downgrade.png" />
                                                <TextBlock
                                                    x:Name="RollBackVersion"
                                                    Margin="0,-2,5,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="15"
                                                    Text="{Binding UpdateState.RollBackVersion, StringFormat='Rollback to {0}', UpdateSourceTrigger=PropertyChanged}" />


                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>

                                <Button
                                    x:Name="UpdateByZipFile"
                                    Width="auto"
                                    Height="30"
                                    Margin="0,0,0,15"
                                    Padding="5"
                                    HorizontalAlignment="Left"
                                    Command="{Binding UpdateByZipCommand}"
                                    Opacity="0.7"
                                    Style="{StaticResource UpdatedGreenButtonStyle}">
                                    <Button.ContentTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Image
                                                    Height="18"
                                                    Margin="0,0,4,0"
                                                    Source="/Img/Icons/Upload.png" />
                                                <TextBlock
                                                    Margin="0,-2,5,0"
                                                    VerticalAlignment="Center"
                                                    FontSize="15"
                                                    Text="Update with ZIP" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </Button.ContentTemplate>
                                </Button>

                                <StackPanel Orientation="Horizontal">
                                    <Button
                                        x:Name="ResetFavorites"
                                        Width="85"
                                        Height="25"
                                        Margin="0,0,5,15"
                                        HorizontalAlignment="Left"
                                        Command="{Binding ResetFavoritesCommand}"
                                        Content="Reset Status"
                                        Style="{DynamicResource Status_Button_style}" />
                                    <Button
                                        x:Name="OpenConfigFolder"
                                        Width="120"
                                        Height="25"
                                        Margin="5,0,5,15"
                                        Command="{Binding OpenConfigFolderCommand}"
                                        Content="Open config folder"
                                        Style="{DynamicResource Status_Button_style}" />
                                    <Button
                                        x:Name="OpenLogFolder"
                                        Width="101"
                                        Height="25"
                                        Margin="5,0,5,15"
                                        Command="{Binding OpenLogFolderCommand}"
                                        Content="Open log folder"
                                        Style="{DynamicResource Status_Button_style}" />

                                </StackPanel>
                            </StackPanel>
                        </Grid>


                    </Grid>
</UserControl>
