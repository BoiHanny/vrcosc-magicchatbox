<UserControl
    x:Class="vrcosc_magicchatbox.UI.Pages.Options.SpotifySection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sections="clr-namespace:vrcosc_magicchatbox.ViewModels.Sections"
    d:DataContext="{d:DesignInstance Type=sections:SpotifySectionViewModel,
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Resources/SharedConverters.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0,5,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.Background>
            <LinearGradientBrush SpreadMethod="Pad" StartPoint="1,1" EndPoint="0,0">
                <GradientStop Color="{StaticResource SurfaceGradientStartColor}" />
                <GradientStop Offset="1" Color="{StaticResource SurfaceGradientEndColor}" />
            </LinearGradientBrush>
        </Grid.Background>

        <ToggleButton
            Grid.Row="0"
            Width="Auto"
            Height="30"
            HorizontalAlignment="Left"
            FontSize="15"
            FontWeight="Bold"
            Foreground="{StaticResource TextSectionHeaderBrush}"
            IsChecked="{Binding AppSettings.Settings_Spotify, Mode=TwoWay}"
            Style="{StaticResource ExpandCollapseToggleButtonStyle}"
            Tag="Spotify options"
            TextOptions.TextRenderingMode="ClearType" />

        <Grid
            Grid.Row="1"
            Height="Auto"
            Margin="34,10,0,0"
            Visibility="{Binding AppSettings.Settings_Spotify, Converter={StaticResource InverseBoolToHiddenConverter}, UpdateSourceTrigger=PropertyChanged}">
            <StackPanel>
                <!--  Pre-release banner  -->
                <Border
                    Margin="0,0,0,10"
                    BorderBrush="{StaticResource StatusWarningBrush}"
                    BorderThickness="1"
                    Style="{StaticResource OptionCardStyle}">
                    <TextBlock
                        FontFamily="Albert Sans Thin"
                        FontSize="13"
                        Foreground="{StaticResource StatusWarningBrush}"
                        TextWrapping="Wrap">
                        <Run Text="🧪 Pre-release: The first-class Spotify integration is new in this version. Please report any issues on" />
                        <Hyperlink
                            Foreground="{StaticResource AccentTealBrush}"
                            NavigateUri="https://github.com/BoiHanny/vrcosc-magicchatbox/issues/new/choose"
                            RequestNavigate="Hyperlink_RequestNavigate">
                            <Run Text="GitHub" />
                        </Hyperlink>
                        <Run Text="or in our" />
                        <Hyperlink
                            Foreground="{StaticResource AccentTealBrush}"
                            NavigateUri="https://discord.gg/ZaSFwBfhvG"
                            RequestNavigate="Hyperlink_RequestNavigate">
                            <Run Text="Discord server" />
                        </Hyperlink>
                        <Run Text="." />
                    </TextBlock>
                </Border>

                <Border Style="{StaticResource OptionCardStyle}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button
                                Width="auto"
                                Height="30"
                                Padding="5"
                                Click="ConnectSpotify_Click"
                                IsEnabled="{Binding IsConnecting, Converter={StaticResource InvertBooleanConverter}}"
                                Style="{StaticResource Status_Button_style}"
                                Visibility="{Binding Display.IsConnected, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <Image
                                        Width="18"
                                        Height="18"
                                        Margin="0,0,5,0"
                                        Source="/Img/Icons/spotify_ico.png" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Text="Connect Spotify" />
                                </StackPanel>
                            </Button>
                            <Button
                                Width="auto"
                                Height="30"
                                Padding="5"
                                Command="{Binding DisconnectSpotifyCommand}"
                                Style="{StaticResource Status_Button_style}"
                                Visibility="{Binding Display.IsConnected, Converter={StaticResource BoolToVisibilityConverter}}">
                                <StackPanel Orientation="Horizontal">
                                    <Image
                                        Width="18"
                                        Height="18"
                                        Margin="0,0,5,0"
                                        Source="/Img/Icons/spotify_ico.png" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontSize="14"
                                        Text="Disconnect Spotify" />
                                </StackPanel>
                            </Button>
                            <Button
                                Width="auto"
                                Height="30"
                                Margin="6,0,0,0"
                                Padding="5"
                                Command="{Binding RefreshSpotifyCommand}"
                                Style="{StaticResource Status_Button_style}"
                                Visibility="{Binding Display.IsConnected, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="14"
                                    Text="Refresh now" />
                            </Button>
                        </StackPanel>
                        <TextBlock
                            Margin="2,6,0,0"
                            Style="{StaticResource OptionHelpTextStyle}"
                            Text="{Binding StatusText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource OptionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource OptionSubsectionHeaderStyle}" Text="Security setup" />
                        <TextBlock
                            Margin="0,3,0,6"
                            Style="{StaticResource OptionHelpTextStyle}"
                            Text="Create a Spotify Developer app, add redirect URI http://localhost:7387/callback/, then paste only the public Client ID. MagicChatbox never asks for a client secret." />
                        <StackPanel Orientation="Horizontal">
                            <TextBox
                                Width="360"
                                Padding="5,0,0,0"
                                VerticalContentAlignment="Center"
                                FontSize="15"
                                Text="{Binding Settings.ClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button
                                Width="170"
                                Height="28"
                                Margin="8,0,0,0"
                                Command="{Binding OpenDeveloperDashboardCommand}"
                                Content="Open dashboard ↗"
                                Style="{StaticResource Status_Button_style}" />
                        </StackPanel>
                        <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                            <TextBlock
                                Width="76"
                                VerticalAlignment="Center"
                                FontFamily="Albert Sans Thin"
                                Foreground="{StaticResource TextLabelBrush}"
                                Text="Redirect URI" />
                            <TextBox
                                Width="276"
                                Margin="8,0,8,0"
                                Padding="5,0,0,0"
                                VerticalContentAlignment="Center"
                                FontSize="13"
                                IsReadOnly="True"
                                Text="{Binding RedirectUri, Mode=OneWay}" />
                            <Button
                                Width="70"
                                Height="26"
                                Command="{Binding CopyRedirectUriCommand}"
                                Content="Copy"
                                Style="{StaticResource Status_Button_style}" />
                        </StackPanel>
                        <CheckBox
                            Margin="0,8,0,0"
                            IsChecked="{Binding Settings.AutoConnectOnStartup, Mode=TwoWay}"
                            Style="{DynamicResource SettingsCheckbox}">
                            Auto-connect on startup
                        </CheckBox>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource OptionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource OptionSubsectionHeaderStyle}" Text="Output template" />
                        <TextBlock
                            Margin="0,3,0,4"
                            Style="{StaticResource OptionHelpTextStyle}"
                            Text="Tokens: {play_icon}, {title}, {artist}, {album}, {device}, {progress}, {seekbar}, {elapsed}, {duration}, {remaining}, {percent}, {liked_icon}, {explicit_icon}, {shuffle_icon}, {repeat_icon}, {queue}" />
                        <Button
                            Width="105"
                            Height="25"
                            Margin="0,0,0,5"
                            HorizontalAlignment="Left"
                            Command="{Binding CopyTemplateTokensCommand}"
                            Content="Copy tokens"
                            Style="{StaticResource Status_Button_style}" />
                        <StackPanel Orientation="Horizontal">
                            <TextBox
                                Width="420"
                                Padding="5,0,0,0"
                                VerticalContentAlignment="Center"
                                FontSize="15"
                                Text="{Binding Settings.OutputTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ComboBox
                                Width="130"
                                Margin="8,0,0,0"
                                FontSize="12"
                                ItemsSource="{Binding PresetNames}"
                                SelectedItem="{Binding SelectedPresetName, Mode=TwoWay}" />
                        </StackPanel>
                        <TextBox
                            Width="420"
                            Margin="0,6,0,0"
                            Padding="5,0,0,0"
                            VerticalContentAlignment="Center"
                            FontSize="15"
                            Text="{Binding Settings.PartyTemplate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Border
                            Margin="0,8,0,0"
                            Padding="10,8"
                            Background="#1A1DB954"
                            BorderBrush="{StaticResource AccentSpotifyBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Image
                                        Width="14"
                                        Height="14"
                                        Margin="0,0,6,0"
                                        VerticalAlignment="Center"
                                        Source="/Img/Icons/spotify_ico.png" />
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="Albert Sans Thin"
                                        FontSize="11"
                                        Foreground="{StaticResource AccentSpotifyBrush}"
                                        Text="CHATBOX OUTPUT PREVIEW" />
                                </StackPanel>
                                <Label
                                    Margin="0,4,0,0"
                                    Content="{Binding OutputPreview, UpdateSourceTrigger=PropertyChanged}"
                                    FontSize="14"
                                    Foreground="{StaticResource TextPrimaryBrush}" />
                                <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                                    <TextBlock
                                        VerticalAlignment="Center"
                                        FontFamily="Albert Sans Thin"
                                        FontSize="11"
                                        Foreground="{StaticResource TextMutedBrush}"
                                        Text="{Binding PreviewLengthText, StringFormat='Characters: {0}'}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource OptionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource OptionSubsectionHeaderStyle}" Text="Privacy and token toggles" />
                        <WrapPanel Margin="0,4,0,0">
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.AllowTrackTitleInOutput, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Allow title
                            </CheckBox>
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.AllowArtistInOutput, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Allow artist
                            </CheckBox>
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.AllowAlbumInOutput, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Allow album
                            </CheckBox>
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.AllowDeviceInOutput, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Allow device
                            </CheckBox>
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.PrivacyMode, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Privacy mode
                            </CheckBox>
                        </WrapPanel>
                        <WrapPanel Margin="0,4,0,0">
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.ShowTitle, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Title token
                            </CheckBox>
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.ShowArtist, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Artist token
                            </CheckBox>
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.ShowAlbum, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Album token
                            </CheckBox>
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.ShowProgress, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Progress token
                            </CheckBox>
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.ShowLiked, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Liked token
                            </CheckBox>
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.ShowShuffle, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Shuffle token
                            </CheckBox>
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.ShowRepeat, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Repeat token
                            </CheckBox>
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.PartyModeEnabled, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Party/DJ mode
                            </CheckBox>
                        </WrapPanel>
                        <StackPanel Margin="0,6,0,0" Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextLabelBrush}"
                                Text="Progress style" />
                            <ComboBox
                                Width="120"
                                Margin="8,0,16,0"
                                ItemsSource="{Binding ProgressDisplayModes}"
                                SelectedItem="{Binding Settings.ProgressDisplayMode, Mode=TwoWay}" />
                            <CheckBox IsChecked="{Binding Settings.AutoDowngradeProgress, Mode=TwoWay}" Style="{DynamicResource SettingsCheckbox}">Auto-downgrade if too long</CheckBox>
                        </StackPanel>
                        <TextBlock
                            Margin="2,4,0,0"
                            Style="{StaticResource OptionHelpTextStyle}"
                            Text="Pick a seekbar style from the shared MediaLink styles. Create and import custom styles in the Media Link section." />
                        <StackPanel
                            Margin="0,6,0,0"
                            Orientation="Horizontal"
                            Visibility="{Binding IsSeekbarMode, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextLabelBrush}"
                                Text="Seekbar style" />
                            <ComboBox
                                Width="280"
                                Margin="8,0,0,0"
                                DisplayMemberPath="StyleName"
                                ItemsSource="{Binding SeekbarStyles}"
                                SelectedItem="{Binding SelectedSeekbarStyle, Mode=TwoWay}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource OptionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource OptionSubsectionHeaderStyle}" Text="Widget and polling" />
                        <WrapPanel Margin="0,4,0,0">
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.ShowWidgetProgress, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Show progress
                            </CheckBox>
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.ShowWidgetDevice, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Show device
                            </CheckBox>
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.ShowWidgetControls, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Show controls
                            </CheckBox>
                            <CheckBox
                                Margin="0,0,12,4"
                                IsChecked="{Binding Settings.ShowWidgetVolume, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Show volume
                            </CheckBox>
                        </WrapPanel>
                        <StackPanel Margin="0,4,0,0" Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextLabelBrush}"
                                Text="Active poll (sec)" />
                            <TextBox
                                Width="50"
                                Margin="8,0,16,0"
                                Text="{Binding Settings.PollingIntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                VerticalAlignment="Center"
                                Foreground="{StaticResource TextLabelBrush}"
                                Text="Idle poll (sec)" />
                            <TextBox
                                Width="50"
                                Margin="8,0,0,0"
                                Text="{Binding Settings.IdlePollingIntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
