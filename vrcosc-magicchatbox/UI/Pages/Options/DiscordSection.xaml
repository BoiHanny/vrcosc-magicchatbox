<UserControl
    x:Class="vrcosc_magicchatbox.UI.Pages.Options.DiscordSection"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sections="clr-namespace:vrcosc_magicchatbox.ViewModels.Sections"
    d:DataContext="{d:DesignInstance Type=sections:DiscordSectionViewModel,
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Resources/SharedConverters.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="0,5,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.Background>
            <LinearGradientBrush SpreadMethod="Pad" StartPoint="1,1" EndPoint="0,0">
                <GradientStop Color="{StaticResource SurfaceGradientStartColor}" />
                <GradientStop Offset="1" Color="{StaticResource SurfaceGradientEndColor}" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Grid.Row="0">
            <ToggleButton
                Width="Auto"
                Height="30"
                HorizontalAlignment="Left"
                FontSize="15"
                FontWeight="Bold"
                Foreground="{StaticResource TextSectionHeaderBrush}"
                IsChecked="{Binding AppSettings.Settings_Discord, Mode=TwoWay}"
                Style="{StaticResource ExpandCollapseToggleButtonStyle}"
                Tag="Discord voice options"
                TextOptions.TextRenderingMode="ClearType" />
        </Grid>

        <Grid
            Grid.Row="1"
            Height="Auto"
            Margin="34,10,0,0"
            Visibility="{Binding AppSettings.Settings_Discord, Converter={StaticResource InverseBoolToHiddenConverter}, UpdateSourceTrigger=PropertyChanged}">
            <StackPanel>

                <!--  Pre-release banner  -->
                <Border
                    Margin="0,0,0,10"
                    BorderBrush="{StaticResource StatusWarningBrush}"
                    BorderThickness="1"
                    Style="{StaticResource OptionCardStyle}">
                    <TextBlock
                        FontFamily="Albert Sans Thin"
                        FontSize="13"
                        Foreground="{StaticResource StatusWarningBrush}"
                        TextWrapping="Wrap">
                        <Run Text="🧪 Pre-release: Discord voice detection is in testing. Please report any issues on" />
                        <Hyperlink
                            Foreground="{StaticResource AccentTealBrush}"
                            NavigateUri="https://github.com/BoiHanny/vrcosc-magicchatbox/issues/new/choose"
                            RequestNavigate="Hyperlink_RequestNavigate">
                            <Run Text="GitHub" />
                        </Hyperlink>
                        <Run Text="or open a ticket in our" />
                        <Hyperlink
                            Foreground="{StaticResource AccentTealBrush}"
                            NavigateUri="https://discord.gg/ZaSFwBfhvG"
                            RequestNavigate="Hyperlink_RequestNavigate">
                            <Run Text="Discord server" />
                        </Hyperlink>
                        <Run Text="." />
                    </TextBlock>
                </Border>

                <!--  Feature overview  -->
                <Border
                    Margin="0,0,0,6"
                    Padding="10,8"
                    Background="{StaticResource SurfaceDarkBrush}"
                    BorderBrush="{StaticResource AccentDeepPurpleBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                    <StackPanel>
                        <TextBlock
                            FontFamily="Albert Sans"
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource AccentLightPurpleBrush}"
                            Text="What each feature does" />
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border
                                Grid.Column="0"
                                Padding="8"
                                Background="{StaticResource SurfaceCardBrush}"
                                CornerRadius="5">
                                <StackPanel>
                                    <TextBlock
                                        FontFamily="Albert Sans"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource AccentDiscordBrush}"
                                        Text="🎮  Rich Presence" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontFamily="Albert Sans Thin"
                                        FontSize="11"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="Shows your VRChat status in your Discord profile — the RICH toggle on the integrations page. Uses the bundled app ID automatically."
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontFamily="Albert Sans Thin"
                                        FontSize="11"
                                        Foreground="{StaticResource StatusSuccessBrush}"
                                        Text="✔  No setup required" />
                                </StackPanel>
                            </Border>
                            <Border
                                Grid.Column="2"
                                Padding="8"
                                Background="{StaticResource SurfaceCardBrush}"
                                CornerRadius="5">
                                <StackPanel>
                                    <TextBlock
                                        FontFamily="Albert Sans"
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Foreground="{StaticResource AccentTealBrush}"
                                        Text="🎙  Voice Detection" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontFamily="Albert Sans Thin"
                                        FontSize="11"
                                        Foreground="{StaticResource TextPrimaryBrush}"
                                        Text="Shows who is speaking in your VC in the chatbox — the DESKTOP / VR toggles. Requires your own Discord Developer app (free, ~2 min)."
                                        TextWrapping="Wrap" />
                                    <TextBlock
                                        Margin="0,4,0,0"
                                        FontFamily="Albert Sans Thin"
                                        FontSize="11"
                                        Foreground="{StaticResource StatusWarningBrush}"
                                        Text="⚙  One-time setup below" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!--  Connect / Connected + Disconnect  -->
                <Border Style="{StaticResource OptionCardStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <Button
                                Width="auto"
                                Height="30"
                                Padding="5"
                                Command="{Binding ConnectDiscordCommand}"
                                IsEnabled="{Binding IsConnecting, Converter={StaticResource InvertBooleanConverter}}"
                                Style="{StaticResource Status_Button_style}"
                                Visibility="{Binding HasSavedToken, Converter={StaticResource InverseBoolToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}">
                                <Button.ContentTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Image
                                                Width="21"
                                                Height="18"
                                                Margin="0,0,3,0"
                                                Source="/Img/Icons/Discord.png" />
                                            <TextBlock
                                                Margin="0,-2,5,0"
                                                VerticalAlignment="Center"
                                                FontSize="14"
                                                Text="Connect with Discord" />
                                        </StackPanel>
                                    </DataTemplate>
                                </Button.ContentTemplate>
                            </Button>
                            <Button
                                Width="auto"
                                Height="30"
                                Padding="5"
                                Command="{Binding ConnectDiscordCommand}"
                                Style="{StaticResource Status_Button_style}"
                                Visibility="{Binding HasSavedToken, Converter={StaticResource InverseBoolToHiddenConverter}, UpdateSourceTrigger=PropertyChanged}">
                                <Button.ContentTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Image
                                                Width="15"
                                                Height="15"
                                                Margin="2,0,5,0"
                                                VerticalAlignment="Center"
                                                Source="/Img/Icons/yes.png" />
                                            <TextBlock
                                                Margin="0,-2,5,0"
                                                VerticalAlignment="Center"
                                                FontSize="14"
                                                Text="Connected with Discord" />
                                        </StackPanel>
                                    </DataTemplate>
                                </Button.ContentTemplate>
                            </Button>
                            <Button
                                Width="20"
                                Height="30"
                                Margin="-5,0,0,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="{StaticResource StatusErrorDarkerBrush}"
                                BorderThickness="0"
                                Command="{Binding DisconnectDiscordCommand}"
                                Cursor="Hand"
                                Style="{DynamicResource DisconnectPulsoid}"
                                Visibility="{Binding HasSavedToken, Converter={StaticResource InverseBoolToHiddenConverter}, UpdateSourceTrigger=PropertyChanged}">
                                <Grid>
                                    <Image
                                        Width="15"
                                        Height="15"
                                        RenderOptions.BitmapScalingMode="Linear"
                                        Source="/Img/Icons/Cross_v1_ico.png" />
                                </Grid>
                            </Button>
                        </StackPanel>

                    </Grid>
                </Border>

                <!--  Live status  -->
                <TextBlock
                    Width="auto"
                    Margin="2,0,0,4"
                    Style="{StaticResource OptionHelpTextStyle}"
                    Text="{Binding StatusText, UpdateSourceTrigger=PropertyChanged}" />

                <!--  Feature split / setup guide  -->
                <Border Style="{StaticResource OptionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource OptionSubsectionHeaderStyle}" Text="🎙  Voice Detection setup (one-time)" />
                        <TextBlock
                            Margin="0,2,0,8"
                            Style="{StaticResource OptionHelpTextStyle}"
                            Text="Discord doesn't allow third-party apps to read voice data directly, so you create your own free developer app. It stays private — only you use it."
                            TextWrapping="Wrap" />

                        <!--  Step 1  -->
                        <Border
                            Margin="0,0,0,5"
                            Padding="8"
                            Background="{StaticResource SurfaceDarkBrush}"
                            CornerRadius="5">
                            <StackPanel>
                                <TextBlock
                                    FontFamily="Albert Sans"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource AccentLightPurpleBrush}"
                                    Text="Step 1 — Create a Discord Developer app" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontFamily="Albert Sans Thin"
                                    FontSize="12"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    TextWrapping="Wrap">
                                    <Run Text="Click" />
                                    <Run FontWeight="SemiBold" Text="Open Developer Portal" />
                                    <Run Text="→ log in → click" />
                                    <Run FontWeight="SemiBold" Text="New Application" />
                                    <Run Text="→ give it any name (e.g. MagicChatbox) → click" />
                                    <Run FontWeight="SemiBold" Text="Create" />
                                    <Run Text="." />
                                </TextBlock>
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontFamily="Albert Sans Thin"
                                    FontSize="12"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    TextWrapping="Wrap">
                                    <Run Text="Then copy the" />
                                    <Run FontWeight="SemiBold" Text="Application ID" />
                                    <Run Text="from the General Information page and paste it in the field below." />
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!--  Step 2  -->
                        <Border
                            Margin="0,0,0,5"
                            Padding="8"
                            Background="{StaticResource SurfaceDarkBrush}"
                            CornerRadius="5">
                            <StackPanel>
                                <TextBlock
                                    FontFamily="Albert Sans"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource AccentLightPurpleBrush}"
                                    Text="Step 2 — Add the Redirect URI" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontFamily="Albert Sans Thin"
                                    FontSize="12"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    TextWrapping="Wrap">
                                    <Run Text="In your Developer Portal app, go to" />
                                    <Run FontWeight="SemiBold" Text="OAuth2" />
                                    <Run Text="→ scroll to" />
                                    <Run FontWeight="SemiBold" Text="Redirects" />
                                    <Run Text="→ click" />
                                    <Run FontWeight="SemiBold" Text="Add Redirect" />
                                    <Run Text="→ paste the Redirect URI shown below → click" />
                                    <Run FontWeight="SemiBold" Text="Save Changes" />
                                    <Run Text="." />
                                </TextBlock>
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontFamily="Albert Sans Thin"
                                    FontSize="11"
                                    Foreground="{StaticResource StatusWarningBrush}"
                                    Text="⚠  The URI must match exactly — copy it using the button below."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!--  Step 3  -->
                        <Border
                            Margin="0,0,0,8"
                            Padding="8"
                            Background="{StaticResource SurfaceDarkBrush}"
                            CornerRadius="5">
                            <StackPanel>
                                <TextBlock
                                    FontFamily="Albert Sans"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource AccentLightPurpleBrush}"
                                    Text="Step 3 — Connect" />
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontFamily="Albert Sans Thin"
                                    FontSize="12"
                                    Foreground="{StaticResource TextPrimaryBrush}"
                                    TextWrapping="Wrap">
                                    <Run Text="Click" />
                                    <Run FontWeight="SemiBold" Text="Connect with Discord" />
                                    <Run Text="at the top. Your browser will open a Discord authorization page — approve it. MagicChatbox saves the token and will reconnect automatically on startup." />
                                </TextBlock>
                                <TextBlock
                                    Margin="0,4,0,0"
                                    FontFamily="Albert Sans Thin"
                                    FontSize="11"
                                    Foreground="{StaticResource TextMutedBrush}"
                                    Text="Note: Discord opens a local page in your browser. After approving, the browser tab will say 'Discord connected!' and close itself."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                            <TextBlock
                                Width="105"
                                VerticalAlignment="Center"
                                FontFamily="Albert Sans Thin"
                                Foreground="{StaticResource TextLabelBrush}"
                                Text="Application ID" />
                            <Grid
                                Width="260"
                                Height="28"
                                Margin="8,0,8,0"
                                ToolTip="Stored encrypted on this Windows account. Click Edit to reveal/change it.">
                                <TextBox
                                    Padding="5,0,0,0"
                                    VerticalContentAlignment="Center"
                                    FontSize="13"
                                    IsReadOnly="True"
                                    Text="{Binding Modules.Discord.Settings.VoiceClientId, Mode=OneWay, Converter={StaticResource MaskedWeatherCityConverter}}"
                                    Visibility="{Binding Modules.Discord.Settings.VoiceClientIdEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}" />
                                <TextBox
                                    Padding="5,0,0,0"
                                    VerticalContentAlignment="Center"
                                    FontSize="13"
                                    Text="{Binding Modules.Discord.Settings.VoiceClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Visibility="{Binding Modules.Discord.Settings.VoiceClientIdEditing, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>
                            <ToggleButton
                                Width="54"
                                Height="28"
                                Margin="0,0,6,0"
                                Content="Edit"
                                IsChecked="{Binding Modules.Discord.Settings.VoiceClientIdEditing, Mode=TwoWay}"
                                Style="{StaticResource Status_Toggle_style}" />
                            <Button
                                Width="150"
                                Height="28"
                                Command="{Binding OpenDiscordDeveloperPortalCommand}"
                                Content="Open Developer Portal"
                                Style="{StaticResource Status_Button_style}" />
                        </StackPanel>

                        <StackPanel Margin="0,0,0,6" Orientation="Horizontal">
                            <TextBlock
                                Width="105"
                                VerticalAlignment="Center"
                                FontFamily="Albert Sans Thin"
                                Foreground="{StaticResource TextLabelBrush}"
                                Text="Redirect URI" />
                            <TextBox
                                Width="260"
                                Margin="8,0,8,0"
                                Padding="5,0,0,0"
                                VerticalContentAlignment="Center"
                                FontSize="13"
                                IsReadOnly="True"
                                Text="{Binding RedirectUri, Mode=OneWay}" />
                            <Button
                                Width="80"
                                Height="28"
                                Margin="0,0,6,0"
                                Command="{Binding CopyRedirectUriCommand}"
                                Content="Copy"
                                Style="{StaticResource Status_Button_style}" />
                            <Button
                                Width="80"
                                Height="28"
                                Command="{Binding CheckRedirectPortCommand}"
                                Content="Check port"
                                Style="{StaticResource Status_Button_style}" />
                        </StackPanel>

                        <TextBlock
                            Margin="113,0,0,4"
                            FontFamily="Albert Sans Thin"
                            FontSize="11"
                            Foreground="{StaticResource TextLabelBrush}"
                            Text="{Binding RedirectPortStatus}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!--  Behaviour  -->
                <Border Style="{StaticResource OptionCardStyle}">
                    <StackPanel>
                        <CheckBox
                            Margin="0,4,0,0"
                            IsChecked="{Binding Modules.Discord.Settings.AutoConnectOnStartup, Mode=TwoWay}"
                            Style="{DynamicResource SettingsCheckbox}"
                            ToolTip="Automatically connect to Discord when MagicChatbox starts (requires saved token)">
                            Auto-connect on startup
                        </CheckBox>
                    </StackPanel>
                </Border>

                <!--  Template + Presets  -->
                <Border Style="{StaticResource OptionCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Width="auto"
                            Margin="2,0,0,2"
                            Style="{StaticResource OptionHelpTextStyle}"
                            Text="Placeholders: {channel}, {count}, {speaking}, {speaking_count}, {mute_emoji}, {mute_state}, {voice_state}  ·  Use \n for new line" />
                        <Button
                            Width="105"
                            Height="25"
                            Margin="0,0,0,5"
                            HorizontalAlignment="Left"
                            Command="{Binding CopyTemplateTokensCommand}"
                            Content="Copy tokens"
                            Style="{StaticResource Status_Button_style}" />
                        <TextBlock
                            Padding="0,0,0,0"
                            Style="{StaticResource OptionSubsectionHeaderStyle}"
                            Text="Output template" />
                        <StackPanel Margin="0,3,0,0" Orientation="Horizontal">
                            <TextBox
                                Width="340"
                                Padding="5,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalContentAlignment="Center"
                                FontSize="15"
                                Text="{Binding Modules.Discord.Settings.Template, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <ComboBox
                                Width="130"
                                Margin="8,0,0,0"
                                FontSize="12"
                                ItemsSource="{Binding PresetNames}"
                                SelectedItem="{Binding SelectedPresetName, Mode=TwoWay}"
                                ToolTip="Quick-fill a preset template" />
                        </StackPanel>

                        <!--  Live output preview  -->
                        <StackPanel Margin="2,6,0,0" Orientation="Horizontal">
                            <TextBlock
                                MaxWidth="390"
                                VerticalAlignment="Center"
                                Style="{StaticResource OptionHelpTextStyle}"
                                Text="{Binding OutputPreview, StringFormat='Preview: {0}', UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                            <Button
                                Width="90"
                                Height="25"
                                Margin="8,0,0,0"
                                Command="{Binding CopyOutputPreviewCommand}"
                                Content="Copy"
                                Style="{StaticResource Status_Button_style}" />
                            <TextBlock
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                FontFamily="Albert Sans Thin"
                                FontSize="12"
                                Foreground="{StaticResource TextLabelBrush}"
                                Opacity="0.65"
                                Text="{Binding PreviewLengthText}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  Speaker display  -->
                <Border Style="{StaticResource OptionCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Padding="0,0,0,0"
                            FontFamily="Albert Sans Thin"
                            FontSize="15"
                            Foreground="{StaticResource TextLabelBrush}"
                            Text="Max speakers to show" />
                        <StackPanel Margin="0,0,0,5" Orientation="Horizontal">
                            <Slider
                                Width="134.5"
                                Height="12"
                                Margin="2.2,0,4.5,0"
                                IsSnapToTickEnabled="True"
                                Maximum="10"
                                Minimum="1"
                                Style="{StaticResource CustomSlider}"
                                TickFrequency="1"
                                Value="{Binding Modules.Discord.Settings.MaxSpeakingUsersToShow, Mode=TwoWay}" />
                            <TextBlock
                                Width="auto"
                                Padding="5,0"
                                VerticalAlignment="Center"
                                FontFamily="Albert Sans Thin"
                                FontSize="13"
                                Foreground="{StaticResource BorderMutedBrush}"
                                Text="{Binding Modules.Discord.Settings.MaxSpeakingUsersToShow}" />
                        </StackPanel>

                        <TextBlock
                            Padding="0,0,0,0"
                            FontFamily="Albert Sans Thin"
                            FontSize="15"
                            Foreground="{StaticResource TextLabelBrush}"
                            Text="Speaker debounce" />
                        <TextBlock
                            Width="auto"
                            Margin="2,0,0,2"
                            Style="{StaticResource OptionHelpTextStyle}"
                            Text="How long to wait before removing a speaker (prevents flickering)" />
                        <StackPanel Margin="0,0,0,5" Orientation="Horizontal">
                            <Slider
                                Width="134.5"
                                Height="12"
                                Margin="2.2,0,4.5,0"
                                IsSnapToTickEnabled="True"
                                Maximum="2000"
                                Minimum="200"
                                Style="{StaticResource CustomSlider}"
                                TickFrequency="100"
                                Value="{Binding Modules.Discord.Settings.SpeakerDebounceMs, Mode=TwoWay}" />
                            <TextBlock
                                Width="auto"
                                Padding="5,0"
                                VerticalAlignment="Center"
                                FontFamily="Albert Sans Thin"
                                FontSize="13"
                                Foreground="{StaticResource BorderMutedBrush}"
                                Text="{Binding Modules.Discord.Settings.SpeakerDebounceMs}" />
                            <TextBlock
                                Width="auto"
                                Margin="-2,5"
                                VerticalAlignment="Center"
                                FontFamily="Albert Sans Thin"
                                FontSize="13"
                                Foreground="{StaticResource BorderMutedBrush}"
                                Text="ms" />
                        </StackPanel>

                        <CheckBox
                            IsChecked="{Binding Modules.Discord.Settings.HideSelfFromSpeakers, Mode=TwoWay}"
                            Style="{DynamicResource SettingsCheckbox}"
                            ToolTip="Your own name won't appear in the {speaking} list">
                            Hide yourself from the speakers list
                        </CheckBox>

                        <CheckBox
                            IsChecked="{Binding Modules.Discord.Settings.ShowUserCountOnly, Mode=TwoWay}"
                            Style="{DynamicResource SettingsCheckbox}"
                            ToolTip="Replace {speaking} with just the user count">
                            Show user count only (no speaker names)
                        </CheckBox>
                    </StackPanel>
                </Border>

                <!--  Text overrides  -->
                <Border Style="{StaticResource OptionCardStyle}">
                    <StackPanel>
                        <TextBlock
                            Padding="0,0,0,0"
                            FontFamily="Albert Sans Thin"
                            FontSize="15"
                            Foreground="{StaticResource TextLabelBrush}"
                            Text="Text when nobody is speaking" />
                        <TextBox
                            Width="200"
                            Margin="0,3,0,5"
                            Padding="5,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalContentAlignment="Center"
                            FontSize="15"
                            Text="{Binding Modules.Discord.Settings.EmptySpeakingText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock
                            Padding="0,0,0,0"
                            FontFamily="Albert Sans Thin"
                            FontSize="15"
                            Foreground="{StaticResource TextLabelBrush}"
                            Text="Text when not in a voice channel" />
                        <TextBlock
                            Width="auto"
                            Margin="2,0,0,2"
                            Style="{StaticResource OptionHelpTextStyle}"
                            Text="Leave empty to hide Discord from chatbox when not in VC" />
                        <TextBox
                            Width="200"
                            Margin="0,3,0,0"
                            Padding="5,0,0,0"
                            HorizontalAlignment="Left"
                            VerticalContentAlignment="Center"
                            FontSize="15"
                            Text="{Binding Modules.Discord.Settings.NotInVcText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Border>

                <!--  Mute / Deafen emojis  -->
                <Border Style="{StaticResource OptionCardStyle}">
                    <StackPanel>
                        <CheckBox IsChecked="{Binding Modules.Discord.Settings.ShowMuteDeafenEmoji, Mode=TwoWay}" Style="{DynamicResource SettingsCheckbox}">
                            Show mute/deafen emoji in chatbox
                        </CheckBox>

                        <StackPanel
                            Margin="2,4,0,0"
                            Orientation="Horizontal"
                            Visibility="{Binding Modules.Discord.Settings.ShowMuteDeafenEmoji, Converter={StaticResource InverseBoolToHiddenConverter}}">
                            <TextBlock
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                FontFamily="Albert Sans Thin"
                                FontSize="13"
                                Foreground="{StaticResource TextLabelBrush}"
                                Text="Mute:" />
                            <TextBox
                                Width="45"
                                Padding="5,0,0,0"
                                VerticalContentAlignment="Center"
                                FontSize="15"
                                Text="{Binding Modules.Discord.Settings.MuteEmoji, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock
                                Margin="10,0,5,0"
                                VerticalAlignment="Center"
                                FontFamily="Albert Sans Thin"
                                FontSize="13"
                                Foreground="{StaticResource TextLabelBrush}"
                                Text="Deafen:" />
                            <TextBox
                                Width="45"
                                Padding="5,0,0,0"
                                VerticalContentAlignment="Center"
                                FontSize="15"
                                Text="{Binding Modules.Discord.Settings.DeafenEmoji, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!--  OSC parameters  -->
                <Border Style="{StaticResource OptionCardStyle}">
                    <StackPanel>
                        <CheckBox IsChecked="{Binding Modules.Discord.Settings.SendMuteDeafenOsc, Mode=TwoWay}" Style="{DynamicResource SettingsCheckbox}">
                            Send mute/deafen as OSC parameters
                        </CheckBox>
                        <TextBlock
                            Width="auto"
                            Margin="20,0,0,2"
                            Style="{StaticResource OptionHelpTextStyle}"
                            Text="/avatar/parameters/DiscordMuted (Bool)&#x0a;/avatar/parameters/DiscordDeafened (Bool)" />

                        <CheckBox
                            Margin="0,6,0,0"
                            IsChecked="{Binding Modules.Discord.Settings.SendVoiceStateOsc, Mode=TwoWay}"
                            Style="{DynamicResource SettingsCheckbox}">
                            Send voice state as OSC parameters
                        </CheckBox>
                        <TextBlock
                            Width="auto"
                            Margin="20,0,0,0"
                            Style="{StaticResource OptionHelpTextStyle}"
                            Text="/avatar/parameters/DiscordInVC (Bool)&#x0a;/avatar/parameters/DiscordVCCount (Float)&#x0a;/avatar/parameters/DiscordSpeaking (Bool)" />
                    </StackPanel>
                </Border>

                <!--  RICH PRESENCE  -->
                <Border Margin="0,8,0,0" Style="{StaticResource OptionCardStyle}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource OptionSubsectionHeaderStyle}" Text="Discord Rich Presence" />
                        <TextBlock
                            Margin="0,2,0,6"
                            Style="{StaticResource OptionHelpTextStyle}"
                            Text="Show VRChat world info, player count, and join button in your Discord profile." />
                        <CheckBox IsChecked="{Binding Modules.Discord.Settings.EnableRichPresence, Mode=TwoWay}" Style="{DynamicResource SettingsCheckbox}">Enable Rich Presence</CheckBox>

                        <StackPanel Margin="0,6,0,0" Visibility="{Binding Modules.Discord.Settings.EnableRichPresence, Converter={StaticResource InverseBoolToHiddenConverter}}">

                            <TextBlock
                                Margin="0,0,0,2"
                                FontSize="11"
                                Foreground="{StaticResource TextLabelBrush}"
                                Text="Preset:" />
                            <ComboBox
                                MinWidth="200"
                                MaxWidth="300"
                                HorizontalAlignment="Left"
                                FontSize="12"
                                ItemsSource="{Binding RpPresetNames}"
                                SelectedItem="{Binding SelectedRpPresetName, Mode=TwoWay}" />

                            <TextBlock
                                Margin="0,6,0,2"
                                FontSize="11"
                                Foreground="{StaticResource TextLabelBrush}"
                                Text="Details template (line 1):" />
                            <TextBox
                                MinWidth="250"
                                Padding="3,1"
                                FontSize="12"
                                Text="{Binding Modules.Discord.Settings.RichPresenceDetails, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Margin="0,6,0,2"
                                FontSize="11"
                                Foreground="{StaticResource TextLabelBrush}"
                                Text="State template (line 2):" />
                            <TextBox
                                MinWidth="250"
                                Padding="3,1"
                                FontSize="12"
                                Text="{Binding Modules.Discord.Settings.RichPresenceState, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Margin="0,4,0,4"
                                Style="{StaticResource OptionHelpTextStyle}"
                                Text="Variables: {world} {count} {type} {region} {status} {mode} {time} {media} {unique} {peak} {worlds} — Max 128 chars per field." />

                            <CheckBox
                                Margin="0,2,0,0"
                                IsChecked="{Binding Modules.Discord.Settings.RichPresenceShowElapsed, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Show elapsed time since joining world
                            </CheckBox>
                            <CheckBox
                                Margin="0,2,0,0"
                                IsChecked="{Binding Modules.Discord.Settings.RichPresenceShowJoinButton, Mode=TwoWay}"
                                Style="{DynamicResource SettingsCheckbox}">
                                Show Join button (Public instances only)
                            </CheckBox>
                            <TextBlock
                                Margin="20,1,0,4"
                                Style="{StaticResource OptionHelpTextStyle}"
                                Text="Privacy: Join links are only generated for Public instances. Private, Friends+, and Invite+ instances are never shared." />
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
