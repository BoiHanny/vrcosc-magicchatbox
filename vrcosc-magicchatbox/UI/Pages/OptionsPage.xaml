<UserControl
    x:Class="vrcosc_magicchatbox.UI.Pages.OptionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:options="clr-namespace:vrcosc_magicchatbox.UI.Pages.Options"
    xmlns:modules="clr-namespace:vrcosc_magicchatbox.Classes.Modules"
    xmlns:vm="clr-namespace:vrcosc_magicchatbox.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:OptionsPageViewModel,
                                     IsDesignTimeCreatable=False}"
    mc:Ignorable="d"
    Background="{StaticResource SurfaceCardBrush}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Resources/SharedConverters.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <ScrollViewer x:Name="OptionsScrollViewer">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <options:StatusSection x:Name="Section_Status" Grid.Row="0"
                                            DataContext="{Binding StatusSection}" />
                    <options:VrcRadarSection x:Name="Section_VrcRadar" Grid.Row="1"
                                             DataContext="{Binding VrcRadarSection}" />
                    <options:PulsoidSection x:Name="Section_HeartRate" Grid.Row="2"
                                            DataContext="{Binding PulsoidSection}" />
                    <options:TimeOptionsSection x:Name="Section_Time" Grid.Row="3"
                                                DataContext="{Binding TimeOptionsSection}" />
                    <options:WeatherSection x:Name="Section_Weather" Grid.Row="4"
                                            DataContext="{Binding WeatherSection}" />

                    <options:TwitchSection x:Name="Section_Twitch" Grid.Row="5"
                                           DataContext="{Binding TwitchSection}" />

                    <options:DiscordSection x:Name="Section_Discord" Grid.Row="6"
                                            DataContext="{Binding DiscordSection}" />

                    <options:OpenAISection x:Name="Section_OpenAI" Grid.Row="7"
                                           DataContext="{Binding OpenAISection}" />
                    <options:ComponentStatsSection x:Name="Section_ComponentStats" Grid.Row="8"
                                                  DataContext="{Binding ComponentStatsSection}" />
                    <options:NetworkStatisticsSection x:Name="Section_NetworkStatistics" Grid.Row="9"
                                                      DataContext="{Binding NetworkStatisticsSection}" />
                    <options:ChattingOptionsSection x:Name="Section_Chatting" Grid.Row="10"
                                                    DataContext="{Binding ChattingOptionsSection}" />
                    <options:TtsOptionsSection x:Name="TtsOptionsSectionControl" Grid.Row="11"
                                               DataContext="{Binding TtsSection}" />
                    <options:MediaLinkSection x:Name="Section_MediaLink" Grid.Row="12"
                                             DataContext="{Binding MediaLinkSection}" />
                    <options:AppOptionsSection x:Name="Section_AppOptions" Grid.Row="13"
                                               DataContext="{Binding AppOptionsSection}" />
                    <options:EggDevSection Grid.Row="14"
                                           DataContext="{Binding EggDevSection}" />

                    <!--  TRACKER BATTERY MANAGER SECTION  -->
                    <options:TrackerBatterySection x:Name="Section_TrackerBattery" Grid.Row="15"
                                                   DataContext="{Binding TrackerBatterySection}" />

                    <options:PrivacySection Grid.Row="16"
                                            DataContext="{Binding PrivacySection}" />

                    <options:WindowActivitySection x:Name="Section_WindowActivity" Grid.Row="17"
                                                    DataContext="{Binding WindowActivitySection}" />

                    <Grid Grid.Row="18" Margin="0,5,0,10">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Albert Sans Thin"
                            FontSize="12"
                            Foreground="{StaticResource TextLabelBrush}"
                            TextWrapping="Wrap">
                            <Run Text="By using MagicChatbox, you agree to our" />
                            <!--  Hyperlink to the Terms of Service  -->
                            <Hyperlink
                                Foreground="{StaticResource AccentTealBrush}"
                                NavigateUri="https://github.com/BoiHanny/vrcosc-magicchatbox/blob/master/Security.md"
                                RequestNavigate="Hyperlink_RequestNavigate"
                                ToolTip="View our Terms of Service">
                                <Run Text="Terms of Service" />
                            </Hyperlink>
                            <Run Text="and" />
                            <!--  Hyperlink to the Software License Agreement  -->
                            <Hyperlink
                                Foreground="{StaticResource AccentTealBrush}"
                                NavigateUri="https://github.com/BoiHanny/vrcosc-magicchatbox/blob/master/License.md"
                                RequestNavigate="Hyperlink_RequestNavigate"
                                ToolTip="View our Software License Agreement">
                                <Run Text="Software License Agreement" />
                            </Hyperlink>
                        </TextBlock>
                    </Grid>

                </Grid>
    </ScrollViewer>
</UserControl>