<UserControl
    x:Class="vrcosc_magicchatbox.UI.Pages.IntegrationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:vrcosc_magicchatbox.ViewModels"
    d:DataContext="{d:DesignInstance Type=vm:IntegrationsPageViewModel,
                                     IsDesignTimeCreatable=False}"
    Background="{StaticResource SurfaceCardBrush}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/UI/Resources/SharedConverters.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <ListBox
        x:Name="IntegrationsList"
        HorizontalAlignment="Stretch"
        Background="Transparent"
        BorderThickness="0"
        RenderOptions.BitmapScalingMode="NearestNeighbor"
        ScrollViewer.CanContentScroll="False"
        ScrollViewer.HorizontalScrollBarVisibility="Hidden">
        <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border
                                Width="{Binding ActualWidth, ElementName=IntegrationsList}"
                                Padding="10,0,19,0"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                                <ContentPresenter />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ListBox.ItemContainerStyle>
        <ListBoxItem Name="StatusItem" Opacity="{Binding IntegrationDisplay.StatusOpacity}">
            <Border Margin="5" CornerRadius="5">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="DarkSlateBlue" />
                        <GradientStop Offset="1" Color="{StaticResource AccentDeepPurpleColor}" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="5"
                        Direction="-23"
                        RenderingBias="Performance"
                        ShadowDepth="0"
                        Color="DarkBlue" />
                </Border.Effect>
                <Grid Margin="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!--  Image  -->
                    <Image
                        Grid.Column="0"
                        Width="35"
                        Margin="5"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Effect="{StaticResource ImageShadowEffect}"
                        Source="/Img/Icons/PersonalMsg_ico.png" />
                    <!--  Text Content  -->
                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center">
                        <StackPanel
                            Margin="0,3,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                Effect="{StaticResource TextBlockShadowEffect}"
                                FontFamily="Comfortaa Light"
                                FontSize="20"
                                Foreground="White"
                                RenderOptions.BitmapScalingMode="NearestNeighbor"
                                Text="Personal status"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBlock
                            Margin="0,3,0,0"
                            Effect="{StaticResource TextBlockShadowEffect}"
                            FontFamily="Comfortaa Light"
                            FontSize="13"
                            RenderOptions.BitmapScalingMode="NearestNeighbor"
                            Text="With this integration, you can write an epic status message that will be displayed in the chatbox.."
                            TextWrapping="Wrap">
                            <TextBlock.Foreground>
                                <RadialGradientBrush>
                                    <GradientStop Color="White" />
                                    <GradientStop Offset="1" Color="{StaticResource AccentLightPurpleColor}" />
                                </RadialGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </StackPanel>
                    <!--  Toggle Button  -->
                    <StackPanel
                        Grid.Column="2"
                        Margin="0,5,0,0"
                        VerticalAlignment="Top"
                        Orientation="Horizontal">
                        <Button
                            Margin="0,0,5,0"
                            Command="{Binding ActivateSettingCommand}"
                            CommandParameter="Settings_Status"
                            Style="{StaticResource CustomizePillButton}" />
                        <ToggleButton
                            Width="60"
                            Height="19"
                            Margin="0,0,5,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Content="DESKTOP"
                            IsChecked="{Binding IntegrationSettings.IntgrStatus_DESKTOP, Mode=TwoWay}"
                            Style="{StaticResource GlowyToggleButtonDT}" />
                        <ToggleButton
                            Width="30"
                            Height="19"
                            Margin="0,0,5,0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Content="VR"
                            IsChecked="{Binding IntegrationSettings.IntgrStatus_VR, Mode=TwoWay}"
                            Style="{StaticResource GlowyToggleButtonVR}" />
                    </StackPanel>
                    <CheckBox
                        Name="Status_switch"
                        Grid.Column="3"
                        Margin="5,0,5,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="Update_Click"
                        IsChecked="{Binding IntegrationSettings.IntgrStatus, Mode=TwoWay}"
                        Style="{DynamicResource Switch}" />
                </Grid>
            </Border>
        </ListBoxItem>
        <ListBoxItem Name="WindowActivityItem" Opacity="{Binding IntegrationDisplay.WindowOpacity}">
            <Border Margin="5,0,5,5" CornerRadius="5">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="DarkSlateBlue" />
                        <GradientStop Offset="1" Color="{StaticResource AccentDeepPurpleColor}" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="5"
                        Direction="-23"
                        RenderingBias="Performance"
                        ShadowDepth="0"
                        Color="DarkBlue" />
                </Border.Effect>
                <Grid Margin="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!--  Image  -->
                    <Image
                        Grid.Column="0"
                        Width="45"
                        Margin="1"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Effect="{StaticResource ImageShadowEffect}"
                        RenderOptions.BitmapScalingMode="NearestNeighbor"
                        Source="/Img/Icons/WindowActivity_ico.png" />
                    <!--  Text Content  -->
                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center">
                        <StackPanel
                            Margin="0,3,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                            <TextBlock
                                VerticalAlignment="Center"
                                Effect="{StaticResource TextBlockShadowEffect}"
                                FontFamily="Comfortaa Light"
                                FontSize="20"
                                Foreground="White"
                                RenderOptions.BitmapScalingMode="NearestNeighbor"
                                Text="Window activity"
                                TextWrapping="Wrap" />
                        </StackPanel>

                        <TextBlock
                            Margin="0,3,0,0"
                            Effect="{StaticResource TextBlockShadowEffect}"
                            FontFamily="Comfortaa Light"
                            FontSize="13"
                            RenderTransformOrigin="0.5,0.5"
                            Text="With this integration, you can show if you're in VR or desktop mode, and in desktop mode, it displays the currently focused application."
                            TextWrapping="Wrap">
                            <TextBlock.Foreground>
                                <RadialGradientBrush>
                                    <GradientStop Color="White" />
                                    <GradientStop Offset="1" Color="{StaticResource AccentLightPurpleColor}" />
                                </RadialGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </StackPanel>
                    <!--  Toggle Button  -->
                    <StackPanel
                        Grid.Column="2"
                        Margin="0,5,0,0"
                        VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal">
                            <Button
                                Margin="0,0,5,0"
                                Command="{Binding ActivateSettingCommand}"
                                CommandParameter="Settings_WindowActivity"
                                Style="{StaticResource CustomizePillButton}" />
                            <ToggleButton
                                Width="60"
                                Height="19"
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Content="DESKTOP"
                                IsChecked="{Binding IntegrationSettings.IntgrWindowActivity_DESKTOP, Mode=TwoWay}"
                                Style="{StaticResource GlowyToggleButtonDT}" />
                            <ToggleButton
                                Width="30"
                                Height="19"
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Content="VR"
                                IsChecked="{Binding IntegrationSettings.IntgrWindowActivity_VR, Mode=TwoWay}"
                                Style="{StaticResource GlowyToggleButtonVR}" />
                        </StackPanel>
                        <StackPanel
                            Margin="0,3,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <ToggleButton
                                Width="57"
                                Height="19"
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Content="Force VR"
                                IsChecked="{Binding IntegrationSettings.IntgrScanForce, Mode=TwoWay}"
                                Style="{StaticResource GlowyToggleButton}"
                                Visibility="{Binding IntegrationSettings.IntgrWindowActivity_VR, Converter={StaticResource InverseBoolToHiddenConverter}, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </StackPanel>
                    <CheckBox
                        Name="WindowActivity_switch"
                        Grid.Column="3"
                        Margin="5,0,5,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="Update_Click"
                        IsChecked="{Binding IntegrationSettings.IntgrScanWindowActivity, Mode=TwoWay}"
                        Style="{DynamicResource Switch}" />
                </Grid>
            </Border>
        </ListBoxItem>
        <ListBoxItem Name="HeartRateItem" Opacity="{Binding IntegrationDisplay.HeartRateOpacity}">
            <Border Margin="5,0,5,5" CornerRadius="5">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                        <GradientStop Color="DarkSlateBlue" />
                        <GradientStop Offset="1" Color="{StaticResource AccentDeepPurpleColor}" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="5"
                        Direction="-23"
                        RenderingBias="Performance"
                        ShadowDepth="0"
                        Color="DarkBlue" />
                </Border.Effect>
                <Grid Margin="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="50" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!--  Image  -->
                    <Image
                        Grid.Column="0"
                        Width="35"
                        Margin="5"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Effect="{StaticResource ImageShadowEffect}"
                        RenderOptions.BitmapScalingMode="Linear"
                        Source="/Img/Icons/HeartRate_ico.png" />
                    <!--  Text Content  -->
                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center">
                        <Grid Margin="0,3,0,0" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Effect="{StaticResource TextBlockShadowEffect}"
                                FontFamily="Comfortaa Light"
                                FontSize="20"
                                Foreground="White"
                                RenderOptions.BitmapScalingMode="NearestNeighbor"
                                Text="Pulsoid Heart Rate"
                                TextWrapping="Wrap" />
                            <StackPanel
                                Grid.Column="1"
                                HorizontalAlignment="Left"
                                Orientation="Horizontal">
                                <Border Visibility="{Binding Modules.Pulsoid.PulsoidAccessError, Converter={StaticResource InverseBoolToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBlock
                                        Margin="5,0,0,0"
                                        VerticalAlignment="Center"
                                        Effect="{StaticResource TextBlockShadowEffect}"
                                        FontFamily="Comfortaa Light"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Foreground="LightSeaGreen"
                                        RenderOptions.BitmapScalingMode="NearestNeighbor"
                                        Text="No device connected"
                                        Visibility="{Binding Modules.Pulsoid.PulsoidDeviceOnline, Converter={StaticResource InverseBoolToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                </Border>
                                <TextBlock
                                    Margin="5,0,0,0"
                                    VerticalAlignment="Center"
                                    Effect="{StaticResource TextBlockShadowEffect}"
                                    FontFamily="Comfortaa Light"
                                    FontSize="12"
                                    Foreground="PaleVioletRed"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                                    Text="Something went wrong, check settings"
                                    Visibility="{Binding Modules.Pulsoid.PulsoidAccessError, Converter={StaticResource InverseBoolToHiddenConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                <Border Visibility="{Binding Modules.Pulsoid.PulsoidAccessError, Converter={StaticResource InverseBoolToVisibilityConverter}, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBlock
                                        Margin="5,0,0,0"
                                        VerticalAlignment="Center"
                                        Effect="{StaticResource TextBlockShadowEffect}"
                                        FontFamily="Comfortaa Light"
                                        FontSize="12"
                                        Foreground="#ABA4B8"
                                        RenderOptions.BitmapScalingMode="NearestNeighbor"
                                        Text="{Binding Modules.Pulsoid.HeartRateLastUpdate, StringFormat='{}{0:T}'}"
                                        Visibility="{Binding IntegrationSettings.IntgrHeartRate, Converter={StaticResource InverseBoolToHiddenConverter}, UpdateSourceTrigger=PropertyChanged}" />
                                </Border>
                                <Border
                                    x:Name="MainDiscoundButton_grid"
                                    Width="auto"
                                    Height="20"
                                    Margin="8,0,0,0"
                                    CornerRadius="5"
                                    Cursor="Hand"
                                    MouseUp="MainDiscoundButton_grid_MouseUp">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0.4,0" EndPoint="0.5,1">
                                            <GradientStop Color="LightSeaGreen" />
                                            <GradientStop Offset="1" Color="{StaticResource AccentDeepPurpleColor}" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            Padding="5,0,0,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="15"
                                            FontWeight="DemiBold"
                                            Foreground="AliceBlue"
                                            Opacity="0.9"
                                            Text="-15%">
                                            <TextBlock.Effect>
                                                <DropShadowEffect
                                                    BlurRadius="5"
                                                    Direction="0"
                                                    Opacity="0.5"
                                                    ShadowDepth="0"
                                                    Color="Black" />
                                            </TextBlock.Effect>
                                        </TextBlock>
                                        <TextBlock
                                            Padding="1,0,3,0"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Top"
                                            FontSize="10"
                                            FontWeight="DemiBold"
                                            Foreground="AliceBlue"
                                            Opacity="0.8"
                                            Text="always">
                                            <TextBlock.Effect>
                                                <DropShadowEffect
                                                    BlurRadius="5"
                                                    Direction="0"
                                                    Opacity="0.5"
                                                    ShadowDepth="0"
                                                    Color="Black" />
                                            </TextBlock.Effect>
                                        </TextBlock>
                                    </StackPanel>


                                    <Border.Effect>
                                        <DropShadowEffect
                                            BlurRadius="10"
                                            Direction="0"
                                            Opacity="0.9"
                                            ShadowDepth="0"
                                            Color="LightSeaGreen" />
                                    </Border.Effect>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <TextBlock
                            Margin="0,3,0,0"
                            Effect="{StaticResource TextBlockShadowEffect}"
                            FontFamily="Comfortaa Light"
                            FontSize="13"
                            RenderOptions.BitmapScalingMode="NearestNeighbor"
                            Text="This integration displays your heart rate in the chatbox and can send it to OSC, similar to the retired 'HRtoVRChat.' Compatible only with Pulsoid."
                            TextWrapping="Wrap">
                            <TextBlock.Foreground>
                                <RadialGradientBrush>
                                    <GradientStop Color="White" />
                                    <GradientStop Offset="1" Color="{StaticResource AccentLightPurpleColor}" />
                                </RadialGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                    </StackPanel>
                    <!--  Toggle Button  -->
                    <StackPanel
                        Grid.Column="2"
                        Margin="0,5,0,0"
                        VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal">
                            <Button
                                Margin="0,0,5,0"
                                Command="{Binding ActivateSettingCommand}"
                                CommandParameter="Settings_HeartRate"
                                Style="{StaticResource CustomizePillButton}" />
                            <ToggleButton
                                Width="60"
                                Height="19"
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Content="DESKTOP"
                                IsChecked="{Binding IntegrationSettings.IntgrHeartRate_DESKTOP, Mode=TwoWay}"
                                Style="{StaticResource GlowyToggleButtonDT}" />
                            <ToggleButton
                                Width="30"
                                Height="19"
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Content="VR"
                                IsChecked="{Binding IntegrationSettings.IntgrHeartRate_VR, Mode=TwoWay}"
                                Style="{StaticResource GlowyToggleButtonVR}" />
                        </StackPanel>
                        <StackPanel
                            Margin="0,3,0,0"
                            HorizontalAlignment="Right"
                            Orientation="Horizontal">
                            <ToggleButton
                                Width="30"
                                Height="19"
                                Margin="0,0,5,0"
                                VerticalAlignment="Center"
                                Content="OSC"
                                IsChecked="{Binding IntegrationSettings.IntgrHeartRate_OSC, Mode=TwoWay}"
                                Style="{StaticResource GlowyToggleButton}" />
                        </StackPanel>
                    </StackPanel>
                    <CheckBox
                        Name="NewHR_Switch"
                        Grid.Column="3"
                        Margin="5,0,5,0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Click="Update_Click"
                        IsChecked="{Binding IntegrationSettings.IntgrHeartRate, Mode=TwoWay}"
                        Style="{DynamicResource Switch}" />
                </Grid>
            </Border>
        </ListBoxItem>
        <ListBoxItem Name="TrackerBatteryItem" Opacity="{Binding IntegrationDisplay.TrackerBatteryOpacity}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border
                    Grid.Row="1"
                    Margin="10,-15,10,5"
                    Background="#230E52"
                    CornerRadius="0,0,5,5"
                    Visibility="{Binding IntegrationSettings.IntgrTrackerBattery, Converter={StaticResource InverseBoolToHiddenConverter}}">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="5"
                            Direction="-23"
                            RenderingBias="Performance"
                            ShadowDepth="0"
                            Color="DarkBlue" />
                    </Border.Effect>
                    <Border Margin="5,15,5,5" CornerRadius="5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="DarkSlateBlue" />
                                <GradientStop Offset="1" Color="{StaticResource AccentDeepPurpleColor}" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel Margin="6">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="Comfortaa Light"
                                    FontSize="13"
                                    Foreground="{StaticResource TextSectionHeaderBrush}"
                                    Text="Active devices" />
                                <TextBlock
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    FontFamily="Albert Sans Thin"
                                    FontSize="14"
                                    Foreground="{StaticResource BorderMutedBrush}"
                                    Text="{Binding IntegrationDisplay.TrackerBatteryDeviceSummary}" />
                                <TextBlock
                                    Margin="10,0,0,0"
                                    VerticalAlignment="Center"
                                    FontFamily="Albert Sans Thin"
                                    FontSize="13"
                                    Foreground="{StaticResource BorderMutedBrush}"
                                    Text="{Binding TrackerBattery_LastScanDisplay}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Tracker.TrackerBatteryActiveDevices}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border
                                            Margin="2"
                                            Padding="6,3"
                                            Background="#2A000000"
                                            CornerRadius="4"
                                            Opacity="{Binding IsConnected, Converter={StaticResource BoolToOpacityConverter}}">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock
                                                    FontSize="12"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    Text="{Binding CustomIcon}" />
                                                <TextBlock
                                                    Margin="4,0,0,0"
                                                    FontSize="12"
                                                    Foreground="{StaticResource TextPrimaryBrush}"
                                                    Text="{Binding DisplayName}" />
                                                <TextBlock
                                                    Margin="6,0,0,0"
                                                    FontSize="12"
                                                    Foreground="{StaticResource BorderMutedBrush}"
                                                    Text="{Binding BatteryPercentage, StringFormat='{}{0}%'}" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Border>
                <Border
                    Grid.Row="0"
                    Margin="5,0,5,5"
                    CornerRadius="5">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                            <GradientStop Color="DarkSlateBlue" />
                            <GradientStop Offset="1" Color="{StaticResource AccentDeepPurpleColor}" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="5"
                            Direction="-23"
                            RenderingBias="Performance"
                            ShadowDepth="0"
                            Color="DarkBlue" />
                    </Border.Effect>
                    <Grid Margin="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Image
                            Grid.Column="0"
                            Width="38"
                            Margin="3"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            Effect="{StaticResource ImageShadowEffect}"
                            RenderOptions.BitmapScalingMode="NearestNeighbor"
                            Source="/Img/Icons/VR_bat_ico.png" />
                        <StackPanel
                            Grid.Column="1"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center">
                            <StackPanel
                                Margin="0,3,0,0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <TextBlock
                                    VerticalAlignment="Center"
                                    Effect="{StaticResource TextBlockShadowEffect}"
                                    FontFamily="Comfortaa Light"
                                    FontSize="20"
                                    Foreground="White"
                                    RenderOptions.BitmapScalingMode="NearestNeighbor"
                                    Text="VR gear battery"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock
                                Margin="0,3,0,0"
                                Effect="{StaticResource TextBlockShadowEffect}"
                                FontFamily="Comfortaa Light"
                                FontSize="13"
                                Foreground="{StaticResource AccentLightPurpleBrush}"
                                RenderOptions.BitmapScalingMode="NearestNeighbor"
                                Text="Monitor controllers and trackers. Output controls live in settings." />
                        </StackPanel>
                        <StackPanel
                            Grid.Column="2"
                            Margin="0,5,100,0"
                            VerticalAlignment="Top"
                            Orientation="Horizontal">
                            <Button
                                Margin="0,0,5,0"
                                Command="{Binding ActivateSettingCommand}"
                                CommandParameter="Settings_TrackerBattery"
                                Style="{StaticResource CustomizePillButton}" />
                        </StackPanel>
                        <CheckBox
                            Name="TrackerBattery_switch"
                            Grid.Column="3"
                            Margin="5,0,5,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Click="Update_Click"
                            IsChecked="{Binding IntegrationSettings.IntgrTrackerBattery, Mode=TwoWay}"
                            Style="{DynamicResource Switch}" />
                    </Grid>
                </Border>
            </Grid>
        </ListBoxItem>
        <ListBoxItem Name="ComponentStatsItem" Opacity="{Binding IntegrationDisplay.ComponentStatOpacity}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>
                <Border
                    Grid.Row="1"
                    Margin="10,-15,10,5"
                    d:Visibility="Visible"
                    Background="#230E52"
                    CornerRadius="0,0,5,5"
                    Visibility="{Binding IntegrationDisplay.ComponentStatsRunning, Converter={StaticResource InverseBoolToHiddenConverter}}">
                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="5"
                            Direction="-23"
                            RenderingBias="Performance"
                            ShadowDepth="0"
                            Color="DarkBlue" />
                    </Border.Effect>
                    <Border Margin="5,15,5,5" CornerRadius="5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                <GradientStop Color="DarkSlateBlue" />
                                <GradientStop Offset="1" Color="{StaticResource AccentDeepPurpleColor}" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <StackPanel Margin="4,4" Orientation="Horizontal">
                                <CheckBox
                                    Height="23"
                                    Margin="3,0"
                                    Content="CPU"
                                    IsChecked="{Binding ComponentStats.IsCPUEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Opacity="{Binding ComponentStats.isCPUAvailable, Converter={StaticResource BoolToOpacityConverter}}"
                                    Style="{StaticResource GlowyToggleButtonMediaLink}" />
                                <CheckBox
                                    Height="23"
                                    Margin="3,0"
                                    Content="GPU"
                                    IsChecked="{Binding ComponentStats.IsGPUEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Opacity="{Binding ComponentStats.IsGPUAvailable, Converter={StaticResource BoolToOpacityConverter}}"
                                    Style="{StaticResource GlowyToggleButtonMediaLink}" />
